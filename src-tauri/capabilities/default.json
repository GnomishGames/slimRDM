{
  "identifier": "default",
  "description": "Default capabilities for SlimRDM",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "store:default",
    "store:allow-get-store",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-has",
    "store:allow-keys",
    "store:allow-values",
    "store:allow-length",
    "store:allow-reset",
    "dialog:default",
    "notification:default",
    "shell:allow-open"
  ]
}
